#include <unordered_map>
using namespace std;

int sockMerchant(int n, int ar_count, int* ar) {
    unordered_map<int, int> freq;
    
    for(int i = 0; i < n; i++) {
        freq[ar[i]]++;
    }
    
    int pairs = 0;
    
    for(auto it : freq) {
        pairs += it.second / 2;
    }
    
    return pairs;
}
